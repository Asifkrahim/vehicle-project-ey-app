# ==============================================================================
# VehicleCare+ — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file!
# ==============================================================================

# Google Gemini AI API Key
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Django Secret Key (generate one at: https://djecrety.ir/)
SECRET_KEY=your_django_secret_key_here

# Debug mode — ALWAYS False in production
DEBUG=False

# Allowed Hosts (comma-separated)
# Example: mysite.vercel.app,www.mysite.com
ALLOWED_HOSTS=

# Production database (Neon, Supabase, Railway, etc.)
# Leave blank to use local SQLite
DATABASE_URL=

# Email (optional — for service confirmation emails)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Auto-created Django superuser on first Vercel deploy
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=your@email.com
DJANGO_SUPERUSER_PASSWORD=ChangeThisPassword!
